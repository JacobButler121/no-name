# The only required credential for live product detection and retailer search.
OPENAI_API_KEY=

# Explicit hackathon target; override if your OpenAI project uses another model.
SPOTTED_OPENAI_MODEL=gpt-5.6-luna

# Use the balanced model only for one image-first web search and visual
# verification pass per unique product. Set this to Luna to minimize cost.
SPOTTED_MATCH_MODEL=gpt-5.6-terra
SPOTTED_MATCH_IMAGE_DETAIL=original

# Optional reverse-image candidate discovery. SerpApi calls Google Lens once
# per unique tracked product; OpenAI still verifies every displayed match.
SERPAPI_API_KEY=

# Preferred transport: Sites holds one selected crop just long enough for Lens
# to fetch it, then the processor immediately deletes it.
SPOTTED_IMAGE_RELAY_URL=https://your-spotted-site.example/api/lens-crops
SPOTTED_RELAY_TOKEN=

# Legacy fallback for a processor already exposed through a secure tunnel.
SPOTTED_PUBLIC_BASE_URL=
SPOTTED_LENS_COUNTRY=us
SPOTTED_LENS_LANGUAGE=en

# Frontend proxy target. The default is shown for clarity.
SPOTTED_PROCESSOR_URL=http://127.0.0.1:8000

# 0 disables the total wall-clock download timer. yt-dlp still applies socket
# timeouts and retries to stalled network requests.
SPOTTED_DOWNLOAD_TIMEOUT_SECONDS=0

# Temporary job directory and session expiry.
SPOTTED_JOB_ROOT=./processor-data
SPOTTED_JOB_TTL_SECONDS=3600
